<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE -->
    <record id="view_tms_roadmap_tree" model="ir.ui.view">
        <field name="name">tms.roadmap.tree</field>
        <field name="model">tms.roadmap</field>
        <field name="arch" type="xml">
            <tree string="Hoja de Ruta">
                <field name="name" optional="show"/>
                <field name="date" optional="show" widget="date"/>
                <field name="transport_id" optional="show"/>
                <field name="assistants" optional="show"/>
                <field name="patente" optional="show"/>
                <field name="in_ruta" optional="show"/>
                <field name="industry_ids" optional="show" widget="many2many_tags"/>
                <field name="total_bulk_defendant" optional="show"/>
                <field name="total_bulk_picking" optional="show"/>
                <field name="total_lvl_compliance" widget="progressbar" options="{'max_value': 100}" optional="show"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'pending'" decoration-success="state == 'completed'" decoration-danger="state == 'canceled'" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_tms_roadmap_form" model="ir.ui.view">
        <field name="name">tms.roadmap.form</field>
        <field name="model">tms.roadmap</field>
        <field name="arch" type="xml">
            <form string="Hoja de Ruta">
                <header>
                    <button name="action_generate_citation"
                            type="object"
                            string="GENERAR CITACIÓN"
                            class="oe_highlight"
                            attrs="{'invisible': [('citation_id','!=',False)]}"/>

                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="draft,pending,completed"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_citation"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-building"
                                attrs="{'invisible': [('citation_id','=',False)]}">
                            <field name="citation_count" widget="statinfo" string="Citación"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="transport_id"/>
                            <field name="patente"/>
                            <field name="assistants"/>
                            <!-- campos invisibles -->
                            <field name="has_delivery" invisible="1"/>
                            <field name="has_pickup" invisible="1"/>
                            <div class="o_form_label">Tipo</div>
                            <div class="o_row" style="gap:6px; align-items:center;">
                                <span class="badge badge-info badge-pill"
                                    attrs="{'invisible': [('has_delivery','=',False)]}">
                                    Entrega
                                </span>
                                <span class="badge badge-warning badge-pill"
                                    attrs="{'invisible': [('has_pickup','=',False)]}">
                                    Retiro
                                </span>
                            </div>
                            <field name="in_ruta" readonly="1"/>
                            <field name="industry_ids" widget="many2many_tags"/>
                            <field name="citation_id" options="{'no_create': True}" domain="[('state', 'not in', ['canceled', 'completed'])]"/>
                        </group>
                        <group>
                            <field name="date" widget="date"/>
                            <field name="total_bulk_defendant" readonly="1"/>
                            <field name="total_bulk_picking" readonly="1"/>
                            <field name="total_lvl_compliance" widget="progressbar" options="{'max_value': 100}"/>
                            <field name="porcentage_efective_hdr" widget="progressbar" options="{'max_value': 100}"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="tms_roadmap_lines_ids" string="Líneas de HDR">
                            <field name="road_maps_line_ids"
                                context="{'default_roadmap_id': active_id,
                                            'default_date': date,
                                            'default_transport_id': transport_id,
                                            'default_patente': patente,
                                            'default_in_ruta': in_ruta}"
                                mode="tree,form">

                                <tree editable="bottom" create="1" edit="1" delete="0" string="Líneas de Hoja de Ruta" decoration-danger="is_canceled == True">
                                    <!-- Columnas tipo Excel -->
                                    <field name="is_canceled" invisible="1"/>
                                    <field name="tms_stock_picking_id" options="{'no_create': True}" optional="show"/>
                                    <field name="type_roadmap" optional="show"/>
                                    <field name="transport_id" readonly="1" options="{'no_create': True}" optional="hide"/>
                                    <field name="patente" readonly="1" optional="hide"/>
                                    <field name="in_ruta" optional="show"/>
                                    <field name="partner_id" optional="show"/>
                                    <field name="direction" optional="show"/>
                                    <field name="industry_id" options="{'no_create': True}" optional="show"/>
                                    <field name="bulk_defendant" optional="show"/>
                                    <field name="bulk_picking" optional="show"/>
                                    <!-- Barra de progreso -->
                                    <field name="lvl_compliance" widget="progressbar" options="{'max_value': 100}" optional="show"/>
                                    <!-- Botón por línea -->
                                    <button name="action_unlink_roadmap"
                                            type="object"
                                            string="Cancelar Envío"
                                            icon="fa-unlink"
                                            class="btn-link"
                                            confirm="Deseas Cancelar esta línea de Hoja de Ruta?"
                                            attrs="{'invisible': [('is_canceled', '=', True)]}"/>
                                    <button name="unlink_roadmap_line"
                                            type="object"
                                            icon="fa-trash"
                                            class="btn-link"
                                            confirm="Deseas Eliminar esta línea de Hoja de Ruta?"
                                            attrs="{'invisible': [('is_canceled', '=', True)]}"/>
                                </tree>
                            </field>
                        </page>
                        <page name="information" string="Información Adicional">
                            <group name="group_information" string="Información Adicional">
                                <group>
                                    <field name="observations" widget="text" colspan="2"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- SEARCH -->
    <record id="view_tms_roadmap_search" model="ir.ui.view">
        <field name="name">tms.roadmap.search</field>
        <field name="model">tms.roadmap</field>
        <field name="arch" type="xml">
            <search string="Buscar Hoja de Ruta">
                <field name="name"/>
                <field name="transport_id"/>
                <field name="road_maps_line_ids"
                    string="Cliente"
                    filter_domain="[('road_maps_line_ids.partner_id', 'ilike', self)]"/>
                <separator/>
                <filter string="Borrador" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Pendiente" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Completada" name="completed" domain="[('state','=','completed')]"/>
                <filter string="Cancelada" name="canceled" domain="[('state','=','canceled')]"/>
                <separator/>
                <group expand="0" string="Agrupar">
                    <filter string="Vehículo" name="grp_transport_id" context="{'group_by':'transport_id'}"/>
                    <filter string="Estado" name="grp_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_tms_roadmap" model="ir.actions.act_window">
        <field name="name">Hojas de Ruta</field>
        <field name="res_model">tms.roadmap</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
