<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TREE -->
    <record id="view_tms_citation_tree" model="ir.ui.view">
        <field name="name">tms.citation.tree</field>
        <field name="model">tms.citation</field>
        <field name="arch" type="xml">
            <tree string="Citaciones">
                <field name="name" optional="show"/>
                <field name="date" optional="show" widget="date"/>
                <field name="mes" optional="show"/>
                <field name="empresa_id" optional="show"/>
                <field name="transport_id" optional="show"/>
                <field name="transport_type_id" optional="show"/>
                <field name="patente_tractor" optional="show"/>
                <field name="patente_semi" optional="show"/>
                <field name="service_id" optional="show"/>
                <field name="area" optional="show"/>
                <field name="hour_citation" widget="float_time" optional="show"/>
                <field name="hour_arrival" widget="float_time" optional="show"/>
                <field name="hiring_id" optional="show"/>
                <field name="total_bulk" optional="show"/>
                <field name="total_bulk_verified" optional="show"/>
                <field name="percentage_verified" widget="progressbar" options="{'max_value': 100}" optional="show"/>
                <field name="amount_service" optional="show"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'pending'" decoration-success="state == 'completed'" decoration-danger="state == 'canceled'" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_tms_citation_form" model="ir.ui.view">
        <field name="name">tms.citation.form</field>
        <field name="model">tms.citation</field>
        <field name="arch" type="xml">
            <form string="Citación">
                <header>
                    <button name="action_post" type="object" string="Confirmar" class="btn-secondary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_completed" type="object" string="Completar Citación" class="btn-success"
                            attrs="{'invisible': [('state', '!=', 'pending')]}"/>
                    <button name="action_cancel" type="object" string="Cancelar Citación" class="btn-danger"
                            attrs="{'invisible': [('state', '=', 'canceled')]}"
                            confirm="¿Está seguro de que desea cancelar esta citación?"/>
                    <button name="action_draft" type="object" string="Revertir a Borrador" class="btn-secondary"
                            attrs="{'invisible': [('state', '!=', 'canceled')]}"
                            confirm="¿Está seguro de que desea revertir esta citación a borrador?"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,pending,completed"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tms_roadmaps"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-building">
                            <field name="tms_roadmap_citation_count" widget="statinfo" string="Hojas de Ruta"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group>

                            <!-- EMPRESA -->
                            <field name="empresa_id"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="empresa_id"
                                groups="tms_service.group_tms_admin"/>

                            <!-- VEHICULO -->
                            <field name="transport_id"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                domain="[('active', '=', True), ('delivery_carrier_id', '=', empresa_id)]"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="transport_id"
                                groups="tms_service.group_tms_admin"
                                domain="[('active', '=', True), ('delivery_carrier_id', '=', empresa_id)]"/>

                            <!-- TIPO VEHICULO -->
                            <field name="transport_type_id"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="transport_type_id"
                                groups="tms_service.group_tms_admin"/>

                            <!-- PATENTES -->
                            <field name="patente_tractor"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="patente_tractor"
                                groups="tms_service.group_tms_admin"/>

                            <field name="patente_semi"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="patente_semi"
                                groups="tms_service.group_tms_admin"/>

                            <!-- SERVICIO / AREA / CONTRATO -->
                            <field name="service_id"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="service_id"
                                groups="tms_service.group_tms_admin"/>

                            <field name="area"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="area"
                                groups="tms_service.group_tms_admin"/>

                            <field name="hiring_id"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="hiring_id"
                                groups="tms_service.group_tms_admin"/>

                        </group>

                        <group>
                            <field name="date" widget="date"/>
                            <field name="mes" readonly="1"/>

                            <!-- HORAS -->
                            <field name="hour_citation"
                                widget="float_time"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="hour_citation"
                                widget="float_time"
                                groups="tms_service.group_tms_admin"/>

                            <field name="hour_arrival"
                                widget="float_time"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>
                            <field name="hour_arrival"
                                widget="float_time"
                                groups="tms_service.group_tms_admin"/>

                            <field name="total_bulk" readonly="1"/>
                            <field name="total_bulk_verified" readonly="1"/>
                            <field name="percentage_verified" widget="progressbar" options="{'max_value': 100}" readonly="1"/>
                            <field name="amount_service"/>

                        </group>
                    </group>

                    <notebook>
                        <page name="tms_roadmap_ids_page" string="Hojas de Ruta">
                            <group>
                                <button name="%(action_tms_citation_link_roadmap_wizard)d"
                                        type="action"
                                        string="Vincular hojas de Ruta"
                                        class="btn-secondary"/>
                            </group>

                            <!-- NORMAL: readonly si no draft -->
                            <field name="tms_roadmap_ids"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                context="{'default_citation_id': active_id}"
                                mode="tree,form"
                                attrs="{'readonly': [('state', '!=', 'draft')]}">
                                <tree string="Hojas de Ruta" delete="false">
                                    <field name="name"/>
                                    <field name="state" invisible="1"/>
                                    <field name="in_ruta"/>
                                    <field name="industry_ids" widget="many2many_tags"/>
                                    <field name="total_bulk_defendant"/>
                                    <field name="total_bulk_picking"/>
                                    <field name="total_lvl_compliance" widget="progressbar" options="{'max_value': 100}"/>
                                    <button name="action_unlink_roadmap"
                                            type="object"
                                            string="Desvincular"
                                            icon="fa-unlink"
                                            class="btn-link"
                                            confirm="¿Desvincular esta hoja de ruta de la citación?"
                                            attrs="{'invisible': [('state', 'in', ['canceled', 'completed'])]}"/>
                                </tree>
                            </field>

                            <!-- ADMIN: editable siempre -->
                            <field name="tms_roadmap_ids"
                                groups="tms_service.group_tms_admin"
                                context="{'default_citation_id': active_id}"
                                mode="tree,form">
                                <tree string="Hojas de Ruta" delete="false">
                                    <field name="name"/>
                                    <field name="state" invisible="1"/>
                                    <field name="in_ruta"/>
                                    <field name="industry_ids" widget="many2many_tags"/>
                                    <field name="total_bulk_defendant"/>
                                    <field name="total_bulk_picking"/>
                                    <field name="total_lvl_compliance" widget="progressbar" options="{'max_value': 100}"/>
                                    <button name="action_unlink_roadmap"
                                            type="object"
                                            string="Desvincular"
                                            icon="fa-unlink"
                                            class="btn-link"
                                            confirm="¿Desvincular esta hoja de ruta de la citación?"
                                            attrs="{'invisible': [('state', 'in', ['canceled', 'completed'])]}"/>
                                </tree>
                            </field>

                        </page>

                        <page string="Observaciones" name="observations_page">

                            <!-- NORMAL -->
                            <field name="observations"
                                groups="base.group_user,!tms_service.group_tms_admin"
                                attrs="{'readonly': [('state', '!=', 'draft')]}"/>

                            <!-- ADMIN -->
                            <field name="observations"
                                groups="tms_service.group_tms_admin"/>

                        </page>
                    </notebook>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids" groups="base.group_user"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>


    <!-- SEARCH -->
    <record id="view_tms_citation_search" model="ir.ui.view">
        <field name="name">tms.citation.search</field>
        <field name="model">tms.citation</field>
        <field name="arch" type="xml">
            <search string="Buscar Citaciones">
                <field name="name"/>
                <field name="empresa_id"/>
                <field name="transport_id"/>
                <field name="service_id"/>
                <field name="area"/>
                <field name="patente_tractor"/>
                <field name="patente_semi"/>

                <separator/>

                <filter string="Borrador" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Pendiente" name="pending" domain="[('state','=','pending')]"/>
                <filter string="Completada" name="completed" domain="[('state','=','completed')]"/>
                <filter string="Cancelada" name="canceled" domain="[('state','=','canceled')]"/>

                <separator/>

                <!-- filtros por área según tu selection -->
                <filter string="P.G" name="area_pg" domain="[('area','=','pg')]"/>
                <filter string="G.C" name="area_gc" domain="[('area','=','gc')]"/>
                <filter string="Millan" name="area_millan" domain="[('area','=','millan')]"/>
                <filter string="Otro" name="area_other" domain="[('area','=','other')]"/>

                <group expand="0" string="Agrupar">
                    <filter string="Mes" name="grp_mes" context="{'group_by':'mes'}"/>
                    <filter string="Empresa" name="grp_empresa" context="{'group_by':'empresa_id'}"/>
                    <filter string="Vehículo" name="grp_transport" context="{'group_by':'transport_id'}"/>
                    <filter string="Servicio" name="grp_service" context="{'group_by':'service_id'}"/>
                    <filter string="Estado" name="grp_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_tms_citation" model="ir.actions.act_window">
        <field name="name">Citaciones</field>
        <field name="res_model">tms.citation</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
