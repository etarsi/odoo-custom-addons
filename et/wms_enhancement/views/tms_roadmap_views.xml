<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <!-- TREE -->
    <record id="view_tms_roadmap_tree_enhancement" model="ir.ui.view">
        <field name="name">tms.roadmap.tree.enhancement</field>
        <field name="model">tms.roadmap</field>
        <field name="inherit_id" ref="tms_service.view_tms_roadmap_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="wms_task_ids" optional="show" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_tms_roadmap_form_enhancement" model="ir.ui.view">
        <field name="name">tms.roadmap.form.enhancement</field>
        <field name="model">tms.roadmap</field>
        <field name="inherit_id" ref="tms_service.view_tms_roadmap_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='citation_id']" position="after">
                <field name="wms_task_ids" widget="many2many_tags"/>
            </xpath>
        </field>
    </record>
</odoo>