<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tms_stock_picking_roadmap_wizard_form" model="ir.ui.view">
        <field name="name">tms.stock.picking.roadmap.wizard.form</field>
        <field name="model">tms.stock.picking.roadmap.wizard</field>
        <field name="arch" type="xml">
            <form string="Hoja de Ruta">
                <group>
                    <field name="type"/>
                    <field name="roadmap_id" attrs="{'invisible':[('type','!=','link')], 'required':[('type','=','link')]}"/>
                    <field name="transport_id" attrs="{'invisible':[('type','!=','create')], 'required':[('type','=','create')]}"/>
                    <field name="industry_ids" widget="many2many_tags" attrs="{'invisible':[('type','!=','create')]}"/>
                    <field name="assistants" attrs="{'invisible':[('type','!=','create')]}"/>
                    <field name="total_bulk_defendant" readonly="1"/>
                    <field name="stock_picking_ids" widget="many2many_tags" options="{'no_create': True}"/>
                </group>

                <separator string="Líneas que se van a crear"/>

                <field name="line_ids" context="{'default_wizard_id': active_id}">
                    <tree editable="bottom" create="0" delete="1">
                        <field name="wms_task_id" string="Tarea WMS" options="{'no_create': True}"/>
                        <field name="tms_stock_picking_id" options="{'no_create': True}"/>
                        <field name="type_roadmap"/>
                        <field name="partner_id"/>
                        <field name="in_ruta"/>
                        <field name="direction"/>
                        <field name="bulto_defendant"/>
                        <field name="bulto_picking"/>

                    </tree>
                </field>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_tms_stock_picking_roadmap_wizard" model="ir.actions.act_window">
        <field name="name">Hoja de Ruta</field>
        <field name="res_model">tms.stock.picking.roadmap.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>