<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <record id="action_forzar_envio_compartido_wms" model="ir.actions.server">
        <field name="name">Forzar envío Compartido</field>
        <field name="model_id" ref="wms_enhancement.model_wms_task"/>
        <field name="binding_model_id" ref="wms_enhancement.model_wms_task"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = records.action_forzar_envio_compartido()</field>
    </record>

    <!--ACTUALIZAR LOTES EN LA LINEA DE TAREAS-->
    <record id="action_update_task_lot_lines" model="ir.actions.server">
        <field name="name">Actualizar Lotes de linea Tareas</field>
        <field name="model_id" ref="wms_enhancement.model_wms_task"/>
        <field name="binding_model_id" ref="wms_enhancement.model_wms_task"/>
        <field name="binding_type">action</field>
        <field name="state">code</field>
        <field name="code">action = records.action_update_task_lot()</field>
    </record>    

    <record id="action_tms_stock_picking_create_roadmap_wizard" model="ir.actions.server">
        <field name="name">Crear Hoja de Ruta</field>
        <field name="model_id" ref="tms_service.model_tms_stock_picking"/>
        <field name="binding_model_id" ref="tms_service.model_tms_stock_picking"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    "type": "ir.actions.act_window",
    "name": "Crear Hoja de Ruta",
    "res_model": "tms.stock.picking.roadmap.wizard",
    "view_mode": "form",
    "target": "new",
    "context": {
        "default_stock_picking_ids": [(6, 0, records.ids)],
        "default_type": "create",
    },
}
        </field>
    </record>

    <record id="action_tms_stock_picking_link_roadmap_wizard" model="ir.actions.server">
        <field name="name">Vincular Hoja de Ruta</field>
        <field name="model_id" ref="tms_service.model_tms_stock_picking"/>
        <field name="binding_model_id" ref="tms_service.model_tms_stock_picking"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
action = {
    "type": "ir.actions.act_window",
    "name": "Vincular Hoja de Ruta",
    "res_model": "tms.stock.picking.roadmap.wizard",
    "view_mode": "form",
    "target": "new",
    "context": {
        "default_stock_picking_ids": [(6, 0, records.ids)],
        "default_type": "link",
    },
}
        </field>
    </record>

    <!--ACTUALIZAR EL action_update_wms_transfer_lines-->
    <record id="action_update_wms_transfer_lines" model="ir.actions.server">
        <field name="name">Actualizar Líneas de Transferencia</field>
        <field name="model_id" ref="wms_enhancement.model_wms_transfer"/>
        <field name="binding_model_id" ref="wms_enhancement.model_wms_transfer"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">action = records.action_update_wms_transfer_lines()</field>
    </record>
</odoo>