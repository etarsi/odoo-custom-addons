<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- MODIFICAR l10n_ar_account_withholding.view_res_partner_arba_alicuot_form-->
    <record id="view_res_partner_arba_alicuot_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.arba_alicuot.form.inherit</field>
        <field name="model">res.partner.arba_alicuot</field>
        <field name="inherit_id" ref="l10n_ar_account_withholding.view_res_partner_arba_alicuot_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='alicuota_percepcion']" position="after">
                <field name="exclusion_percepcion"/>
            </xpath>
            <xpath expr="//field[@name='alicuota_retencion']" position="after">
                <field name="exclusion_retencion"/>
            </xpath>
        </field>
    </record>
</odoo>
