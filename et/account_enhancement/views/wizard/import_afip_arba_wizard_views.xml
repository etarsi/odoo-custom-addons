<odoo>
    <record id="view_import_afip_arba_wizard_form" model="ir.ui.view">
        <field name="name">import.afip.arba.wizard.form</field>
        <field name="model">import.afip.arba.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar IIBB ARBA">
                <group>
                    <field name="month" />
                    <field name="year" />
                </group>

                <footer>
                    <button string="Importar" type="object" name="action_consultar_arba_iibb" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_afip_arba_wizard" model="ir.actions.act_window">
        <field name="name">Importar IIBB ARBA</field>
        <field name="res_model">import.afip.arba.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
