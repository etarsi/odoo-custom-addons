<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_rounding_invoice_wizard_form" model="ir.ui.view">
        <field name="name">account.move.rounding.invoice.wizard.form</field>
        <field name="model">account.move.rounding.invoice.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar facturas de redondeo">
                <group>
                    <field name="line_ids" nolabel="1">
                        <tree create="0" delete="0">
                            <field name="partner_id"/>
                            <field name="company_id"/>
                            <field name="account_id"/>
                            <field name="currency_id"/>
                            <field name="move_count"/>
                            <field name="line_count"/>
                            <field name="amount_total"/>
                            <field name="journal_id"/>
                            <field name="product_id"/>
                            <field name="move_names"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_line_rounding_invoice_wizard" model="ir.actions.act_window">
        <field name="name">Generar facturas de redondeo</field>
        <field name="res_model">account.move.rounding.invoice.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_account_move_rounding_invoice_wizard_form"/>
        <field name="target">new</field>
        <field name="binding_model_id" ref="account.model_account_move_line"/>
        <field name="binding_view_types">list</field>
    </record>
</odoo>