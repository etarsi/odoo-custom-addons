<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_move_balance_transfer_wizard_form" model="ir.ui.view">
        <field name="name">account.move.balance.transfer.wizard.form</field>
        <field name="model">account.move.balance.transfer.wizard</field>
        <field name="arch" type="xml">
            <form string="Transferencia de Saldo">
                <group>
                    <group>
                        <field name="amount_total_invoice" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="line_ids" nolabel="1">
                            <tree create="1" delete="1" edit="1" editable="bottom">
                                <field name="partner_id" optional="show" readonly="1"/>
                                <field name="company_id" optional="show" readonly="1"/>
                                <field name="account_id" optional="hide" readonly="1"/>
                                <field name="journal_id" optional="hide" readonly="1"/>
                                <field name="currency_id" optional="hide" readonly="1"/>
                                <field name="move_count" optional="hide" readonly="1"/>
                                <field name="line_count" optional="hide" readonly="1"/>
                                <field name="amount_total" optional="show"/>
                                <field name="amount_total_origin" optional="show" readonly="1"/>
                                <field name="product_id" optional="hide"/>
                                <field name="move_names" optional="show"/>
                                <field name="partner_id_destination" optional="show"/>
                                <field name="company_id_destination" optional="show"/>
                                <button name="action_duplicate_line" type="object" string="Duplicar" class="btn-primary" icon="fa-copy"/>
                            </tree>
                        </field>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_account_move_line_balance_transfer_wizard" model="ir.actions.act_window">
        <field name="name">Transferencia de Saldo</field>
        <field name="res_model">account.move.balance.transfer.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_account_move_balance_transfer_wizard_form"/>
        <field name="target">new</field>
    </record>
</odoo>