<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- TREE VIEW -->

    <record id="view_partner_tree_order_control" model="ir.ui.view">
        <field name="name">res.partner.tree.order.control</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Control de Pedidos"
                decoration-danger="order_control_state == 'blocked'"
                decoration-success="order_control_state == 'approved'">

                <field name="name"/>
                <field name="vat" string="CUIT"/>
                <field name="city"/>

                <field name="user_id" string="Comercial"/>
                <field name="executive_id" string="Ejecutivo"/>

                <field name="total_debt" string="Deuda Total"/>
                <field name="overdue_debt" string="Deuda Vencida"/>
                <field name="max_overdue_days" string="Días Mora"/>

                <field name="last_purchase_date" string="Última Compra"/>
                <field name="last_purchase_amount" string="Monto Última Compra"/>
                <field name="days_without_purchase" string="Días sin comprar"/>

                <field name="order_control_state" widget="badge" decoration-danger="order_control_state == 'blocked'" decoration-warning="order_control_state == 'unreviewed'" decoration-success="order_control_state == 'approved'"/>
                <field name="credit_alert_summary"/>

            </tree>
        </field>
    </record>


    <record id="view_sale_order_tree_order_control" model="ir.ui.view">
        <field name="name">sale.order.tree.order.control</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <tree string="Control de Pedidos"
                default_order="date_order desc"
                decoration-warning="approval_state == 'rejected'"
                decoration-danger="approval_state == 'blocked'">

                <header>
                    <button name="action_set_approved" type="object" string="Aprobar" class="btn-success"/>
                    <button name="action_set_rejected" type="object" string="Rechazar" class="btn-warning"/>
                    <button name="action_set_pending" type="object" string="Marcar como 'Sin Revisar'"/>
                </header>

                <field name="name" string="Número de pedido"/>
                <!-- <field name="condicion_m2m" string="Condición de Venta"/> -->
                <field name="date_order" string="Fecha"/>
                <field name="partner_id" string="Cliente"/>
                <field name="user_id" string="Comercial"/>
                <field name="executive_id" string="Ejecutivo"/>
                <field name="company_id" string="Compañía"/>
                <!-- <field name="packaging_qty" string="Cantidad de Bultos"/> -->
                <field name="x_discount" string="Descuento"/>
                <field name="amount_total" string="Monto Total"/>
                <field name="payment_term_id" string="Plazos de Pago"/>
                <field name="partner_overdue_debt" string="Deuda Total Vencida"/>
                <field name="approval_state" string="Estado Aprobación" widget="badge" decoration-danger="approval_state == 'blocked'" decoration-warning="approval_state == 'rejected'"/>

            </tree>
        </field>
    </record>

    <!-- FORM VIEW -->

    <record id="view_partner_form_order_control" model="ir.ui.view">
        <field name="name">res.partner.form.order.control</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Control de Pedidos - Cliente">
                <header>
                    <button name="action_set_approved"
                            type="object"
                            string="Autorizar"
                            class="btn-success"
                            attrs="{'invisible': [('order_control_state', '=', 'approved')]}"/>

                    <button name="action_set_blocked"
                            type="object"
                            string="Bloquear"
                            class="btn-danger"
                            attrs="{'invisible': [('order_control_state', '=', 'blocked')]}"/>

                    <button name="action_set_unreviewed"
                            type="object"
                            string="Marcar Sin Revisar"
                            attrs="{'invisible': [('order_control_state', '=', 'unreviewed')]}"/>

                    <field name="order_control_state"
                           widget="statusbar"
                           statusbar_visible="unreviewed,approved,blocked"/>
                </header>

                <sheet>
                    <div class="oe_button_box" name="button_box">                    

                        <!-- DEUDA -->
                        <button name="action_view_debt_composition"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-line-chart">

                            <div class="o_stat_info">
                                <field name="debt_line_count" class="o_stat_value"/>
                                <span class="o_stat_text">Composición de Deuda</span>
                            </div>

                        </button>


                        <!-- FACTURADO -->
                        <button name="action_view_invoices"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o">

                            <div class="o_stat_info">
                                <field name="invoice_count" class="o_stat_value"/>
                                <span class="o_stat_text">Facturado</span>
                            </div>

                        </button>

                        <!-- PEDIDOS -->
                        <button name="action_view_sale_orders"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-shopping-cart">

                            <div class="o_stat_info">
                                <field name="sale_order_count" class="o_stat_value"/>
                                <span class="o_stat_text">Pedidos</span>
                            </div>

                        </button>

                    </div>
                    <div class="oe_title">
                        <h1 class="d-flex align-items-center gap-2">
                            <field name="name" readonly="1"/>

                            <field name="credit_alert_summary"
                                widget="badge"
                                readonly="1"
                                decoration-danger="order_control_state == 'blocked'"
                                decoration-warning="order_control_state == 'unreviewed'"
                                decoration-success="order_control_state == 'approved'"/>
                                
                        </h1>
                    </div>

                    <group>
                        <group string="Datos del Cliente">
                            <field name="vat" string="CUIT" readonly="1"/>
                            <field name="user_id" string="Comercial" readonly="1"/>
                            <field name="executive_id" string="Ejecutivo" readonly="1"/>
                            <field name="city" string="Ciudad" readonly="1"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Resumen">
                            <group>
                                <group string="Resumen Comercial">
                                    <field name="last_purchase_date" string="Última Compra" readonly="1"/>
                                    <field name="last_purchase_amount" string="Monto Última Compra" readonly="1"/>
                                    <field name="days_without_purchase" string="Días sin Comprar" readonly="1"/>
                                    <field name="season_purchase_count" string="Compras Temporada" readonly="1"/>
                                </group>

                                <group string="Resumen Financiero">
                                    <field name="total_debt" string="Deuda Total" readonly="1"/>
                                    <field name="overdue_debt" string="Deuda Vencida" readonly="1"/>
                                    <field name="max_overdue_days" string="Días de Mora" readonly="1"/>
                                    <field name="credit_limit" string="Límite de Crédito" readonly="1"/>
                                </group>
                            </group>

                            
                        </page>

                        <page string="Análisis">
                            <group>                              

                                <group string="Control">
                                    <field name="last_review_date" string="Última Revisión" readonly="1"/>
                                    <field name="last_review_user_id" string="Revisado por" readonly="1"/>
                                    <field name="draft_sale_order_count" string="Pedidos Borrador" readonly="1"/>
                                </group>
                                <group string="Observaciones">
                                    <field name="risk_note" string="Observación del Gerente"/>
                                </group>
                                <group string="Bloqueo">
                                    <field name="block_reason" string="Motivo de Bloqueo"/>
                                </group>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <record id="sale_order_form_inherit_order_control_partner_button" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.order.control.partner.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_order_control_partner"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-user">

                    <div class="o_stat_info">
                        <span class="o_stat_text">Cliente</span>
                    </div>

                </button>
            </xpath>

        </field>
    </record>

    <!-- ACTION -->
    <record id="action_order_control" model="ir.actions.act_window">
        <field name="name">Clientes</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('customer_rank', '&gt;', 0), ('category_id', '!=', 'Propio')]</field>
    </record>

    <record id="action_sale_order_control" model="ir.actions.act_window">
        <field name="name">Pedidos</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('approval_state', 'in', ['pending', 'rejected', 'blocked']), ('state', 'in', ('draft', 'rejected', 'blocked'))]</field>
    </record>

    <!-- ACTION VIEWS -->
    <record id="action_order_control_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_partner_tree_order_control"/>
        <field name="act_window_id" ref="action_order_control"/>
    </record>

    <record id="action_order_control_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_partner_form_order_control"/>
        <field name="act_window_id" ref="action_order_control"/>
    </record>

    <record id="action_sale_order_control_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_sale_order_tree_order_control"/>
        <field name="act_window_id" ref="action_sale_order_control"/>
    </record>

    <record id="action_sale_order_control_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="sale.view_order_form"/>
        <field name="act_window_id" ref="action_sale_order_control"/>
    </record>

    <!-- MENÚ ROOT -->
    <menuitem 
        id="menu_order_control_root"
        name="Control de Pedidos"
        sequence="1"
    />

    <!-- SUBMENÚ CLIENTES -->
    <menuitem 
        id="menu_order_control_clients"
        name="Clientes"
        parent="menu_order_control_root"
        action="action_order_control"
        sequence="10"
    />

    


</odoo>
