<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- TREE VIEW -->

    <record id="view_partner_tree_order_control" model="ir.ui.view">
        <field name="name">res.partner.tree.order.control</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Control de Pedidos"
                decoration-danger="order_control_state == 'blocked'"
                decoration-success="order_control_state == 'approved'">

                <field name="name"/>
                <field name="vat" string="CUIT"/>
                <field name="city"/>

                <field name="user_id" string="Comercial"/>
                <field name="executive_id" string="Ejecutivo"/>

                <field name="total_debt" string="Deuda Total"/>
                <field name="overdue_debt" string="Deuda Vencida"/>
                <field name="max_overdue_days" string="Días Mora"/>

                <field name="last_purchase_date" string="Última Compra"/>
                <field name="last_purchase_amount" string="Monto Última Compra"/>
                <field name="days_without_purchase" string="Días sin comprar"/>

                <field name="order_control_state" widget="badge" decoration-danger="order_control_state == 'blocked'" decoration-warning="order_control_state == 'unreviewed'" decoration-success="order_control_state == 'approved'"/>
                <field name="credit_alert_summary"/>

            </tree>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_order_control" model="ir.actions.act_window">
        <field name="name">Clientes</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('customer_rank', '&gt;', 0)]</field>
    </record>

    <!-- ACTION VIEWS -->
    <record id="action_order_control_tree_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="1"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_partner_tree_order_control"/>
        <field name="act_window_id" ref="action_order_control"/>
    </record>

    <record id="action_order_control_form_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="2"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_partner_form_order_control"/>
        <field name="act_window_id" ref="action_order_control"/>
    </record>

    <!-- MENÚ ROOT -->
    <menuitem 
        id="menu_order_control_root"
        name="Control de Pedidos"
        sequence="1"
    />

    <!-- SUBMENÚ CLIENTES -->
    <menuitem 
        id="menu_order_control_clients"
        name="Clientes"
        parent="menu_order_control_root"
        action="action_order_control"
        sequence="10"
    />

    <!-- FORM VIEW -->

    <record id="view_partner_form_order_control" model="ir.ui.view">
        <field name="name">res.partner.form.order.control</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Control de Pedidos - Cliente">
                <header>
                    <button name="action_set_approved"
                            type="object"
                            string="Autorizar"
                            class="btn-primary"
                            attrs="{'invisible': [('order_control_state', '=', 'approved')]}"/>

                    <button name="action_set_blocked"
                            type="object"
                            string="Bloquear"
                            class="btn-danger"
                            attrs="{'invisible': [('order_control_state', '=', 'blocked')]}"/>

                    <button name="action_set_unreviewed"
                            type="object"
                            string="Marcar Sin Revisar"
                            attrs="{'invisible': [('order_control_state', '=', 'unreviewed')]}"/>

                    <field name="order_control_state"
                           widget="statusbar"
                           statusbar_visible="unreviewed,approved,blocked"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <div class="text-muted">
                            Perfil individual del cliente para análisis comercial y financiero
                        </div>
                    </div>

                    <group>
                        <group string="Datos del Cliente">
                            <field name="vat" string="CUIT" readonly="1"/>
                            <field name="user_id" string="Comercial" readonly="1"/>
                            <field name="executive_id" string="Ejecutivo" readonly="1"/>
                            <field name="city" string="Ciudad" readonly="1"/>
                        </group>

                        <group string="Control">
                            <field name="last_review_date" string="Última Revisión" readonly="1"/>
                            <field name="last_review_user_id" string="Revisado por" readonly="1"/>
                            <field name="draft_sale_order_count" string="Pedidos Borrador" readonly="1"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Resumen">
                            <group>
                                <group string="Resumen Comercial">
                                    <field name="last_purchase_date" string="Última Compra" readonly="1"/>
                                    <field name="last_purchase_amount" string="Monto Última Compra" readonly="1"/>
                                    <field name="days_without_purchase" string="Días sin Comprar" readonly="1"/>
                                    <field name="season_purchase_count" string="Compras Temporada" readonly="1"/>
                                </group>

                                <group string="Resumen Financiero">
                                    <field name="total_debt" string="Deuda Total" readonly="1"/>
                                    <field name="overdue_debt" string="Deuda Vencida" readonly="1"/>
                                    <field name="max_overdue_days" string="Días de Mora" readonly="1"/>
                                    <field name="credit_limit" string="Límite de Crédito" readonly="1"/>
                                </group>
                            </group>

                            <group string="Alertas">
                                <group>
                                    <field name="is_new_customer" string="Cliente Nuevo" readonly="1"/>
                                    <field name="reactivated_customer_alert" string="Cliente Reactivado" readonly="1"/>
                                </group>
                                <group>
                                    <field name="sudden_purchase_alert" string="Compra Inusual" readonly="1"/>
                                    <field name="new_customer_high_risk_alert" string="Cliente Nuevo - Compra Alta" readonly="1"/>
                                </group>
                            </group>

                            <group string="Resumen de Alertas">
                                <field name="credit_alert_summary" string="Alertas" nolabel="1" readonly="1"/>
                            </group>
                        </page>

                        <page string="Análisis">
                            <group>
                                <group string="Observaciones">
                                    <field name="risk_note" string="Observación del Gerente"/>
                                </group>
                                <group string="Bloqueo">
                                    <field name="block_reason" string="Motivo de Bloqueo"/>
                                </group>
                            </group>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


</odoo>
