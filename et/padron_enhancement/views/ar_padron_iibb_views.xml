<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_padron_iibb_form" model="ir.ui.view">
        <field name="name">ar.padron.iibb.form</field>
        <field name="model">ar.padron.iibb</field>
        <field name="arch" type="xml">
            <form string="Padrón IIBB">
                <sheet>
                    <group>
                        <field name="partner_name"/>
                        <field name="cuit"/>
                        <field name="perception_agip"/>
                        <field name="retention_agip"/>
                        <field name="perception_arba"/>
                        <field name="retention_arba"/>
                        <field name="period"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vista Tree para mostrar el nuevo campo gdrive_folder_id -->
    <record id="view_ar_padron_iibb_tree" model="ir.ui.view">
        <field name="name">ar.padron.iibb.tree</field>
        <field name="model">ar.padron.iibb</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_name" optional="show"/>
                <field name="cuit" optional="show"/>
                <field name="perception_agip" optional="show"/>
                <field name="retention_agip" optional="show"/>
                <field name="perception_arba" optional="show"/>
                <field name="retention_arba" optional="show"/>
                <field name="period" optional="show"/>
            </tree>
        </field>
    </record>

    <!-- Acción para abrir la vista del padrón de IIBB -->
    <record id="action_ar_padron_iibb" model="ir.actions.act_window">
        <field name="name">Padrón IIBB</field>
        <field name="res_model">ar.padron.iibb</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_ar_padron_iibb_tree"/>
    </record>
</odoo>
