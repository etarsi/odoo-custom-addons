<odoo>
    <template id="shop_gate" name="Shop Gate">
        <t t-call="website.layout">
            <!-- 👇 Record real, evita el crash del publisher -->
            <t t-set="main_object" t-value="request.website"/>
            <t t-set="title">Acceso a la tienda</t>

            <div class="container my-5" style="max-width:480px">
            <div class="card shadow-sm">
                <div class="card-body">
                <h3 class="mb-3">Acceso a la tienda</h3>
                <t t-if="msg">
                    <div class="alert alert-danger" t-esc="msg"/>
                </t>
                <form method="post">
                    <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input class="form-control" name="password" type="password" required="required" autofocus="autofocus"/>
                    </div>
                    <button class="btn btn-primary w-100" type="submit">Entrar</button>
                </form>
                </div>
            </div>
            </div>
        </t>
    </template>

    <template id="website_sale_products_item_main_gallery_image"
              inherit_id="website_sale.products_item"
              name="Website Sale Products Item Main Gallery Image">

        <xpath expr="//span[@t-field='image_holder.image_1920']" position="replace">
            <t t-if="product.website_main_image_url">
                <img t-att-src="product.website_main_image_url"
                     t-att-alt="product.display_name"
                     itemprop="image"
                     class="d-flex h-100 justify-content-center align-items-center img img-fluid"/>
            </t>

            <t t-else="">
                <span t-field="image_holder.image_1920"
                      t-options="{'widget': 'image', 'preview_image': 'image_1024' if product_image_big else 'image_256', 'itemprop': 'image'}"
                      class="d-flex h-100 justify-content-center align-items-center"/>
            </t>
        </xpath>
    </template>

    <template id="website_sale_shop_product_carousel_gallery"
              inherit_id="website_sale.shop_product_carousel"
              name="Website Sale Shop Product Carousel Gallery">

        <xpath expr="//div[@id='o-carousel-product']" position="replace">

            <t t-set="gallery_images"
               t-value="product.gallery_image_ids.sorted(key=lambda r: ((0 if r.is_main else 1), r.sequence, r.id))"/>

            <t t-if="gallery_images">
                <div id="o-carousel-product"
                     class="carousel slide position-sticky mb-3 overflow-hidden"
                     data-ride="carousel"
                     data-interval="0">

                    <div class="o_carousel_product_outer carousel-outer position-relative flex-grow-1">
                        <div class="carousel-inner h-100">
                            <t t-foreach="gallery_images" t-as="img">
                                <div t-attf-class="carousel-item h-100#{' active' if img_first else ''}">
                                    <div class="d-flex align-items-center justify-content-center h-100">
                                        <img t-att-src="'/product-images/%s' % img.relative_path"
                                             t-att-alt="img.name or product.name"
                                             class="product_detail_img mh-100 img img-fluid"/>
                                    </div>
                                </div>
                            </t>
                        </div>

                        <t t-if="len(gallery_images) &gt; 1">
                            <a class="carousel-control-prev" href="#o-carousel-product" role="button" data-slide="prev">
                                <span class="fa fa-chevron-left fa-2x" role="img" aria-label="Previous" title="Previous"/>
                            </a>
                            <a class="carousel-control-next" href="#o-carousel-product" role="button" data-slide="next">
                                <span class="fa fa-chevron-right fa-2x" role="img" aria-label="Next" title="Next"/>
                            </a>
                        </t>
                    </div>
                </div>

                <!-- Miniaturas abajo -->
                <t t-if="len(gallery_images) &gt; 1">
                    <div class="row mt-2">
                        <t t-foreach="gallery_images" t-as="img">
                            <div class="col-3 mb-2">
                                <a t-att-href="'/product-images/%s' % img.relative_path"
                                   target="_blank">
                                    <img t-att-src="'/product-images/%s' % img.relative_path"
                                         t-att-alt="img.name or product.name"
                                         class="img img-fluid border rounded"/>
                                </a>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Botón ZIP -->
                <div class="mt-2 text-center" t-if="product and product.website_published">
                    <a t-att-href="'/shop/product/%s/download-images-zip' % product.id"
                       class="btn btn-secondary">
                        Descargar imágenes (ZIP)
                    </a>
                </div>
            </t>

            <t t-else="">
                <div id="o-carousel-product"
                     class="carousel slide position-sticky mb-3 overflow-hidden"
                     data-ride="carousel"
                     data-interval="0">

                    <div class="o_carousel_product_outer carousel-outer position-relative flex-grow-1">
                        <div class="carousel-inner h-100">
                            <t t-foreach="product_images" t-as="product_image">
                                <div t-attf-class="carousel-item h-100#{' active' if product_image_first else ''}">
                                    <div t-if="product_image._name == 'product.image' and product_image.embed_code"
                                         class="d-flex align-items-center justify-content-center h-100 embed-responsive embed-responsive-16by9">
                                        <t t-out="product_image.embed_code"/>
                                    </div>
                                    <div t-else=""
                                         t-field="product_image.image_1920"
                                         class="d-flex align-items-center justify-content-center h-100"
                                         t-options="{'widget': 'image', 'preview_image': 'image_1024', 'class': 'product_detail_img mh-100', 'alt-field': 'name', 'zoom': product_image.can_image_1024_be_zoomed and 'image_1920'}"/>
                                </div>
                            </t>
                        </div>

                        <t t-if="len(product_images) &gt; 1">
                            <a class="carousel-control-prev" href="#o-carousel-product" role="button" data-slide="prev">
                                <span class="fa fa-chevron-left fa-2x" role="img" aria-label="Previous" title="Previous"/>
                            </a>
                            <a class="carousel-control-next" href="#o-carousel-product" role="button" data-slide="next">
                                <span class="fa fa-chevron-right fa-2x" role="img" aria-label="Next" title="Next"/>
                            </a>
                        </t>
                    </div>
                </div>
            </t>

        </xpath>

    </template>
</odoo>
