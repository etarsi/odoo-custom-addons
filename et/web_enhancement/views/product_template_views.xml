<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_form_zip_by_code_btn" model="ir.ui.view">
        <field name="name">product.template.form.gdrive.zip.by.code</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- Campo para pegar el Folder ID principal -->
            <xpath expr="//group/group" position="inside">
                <field name="gdrive_folder_id" readonly="1"/>
            </xpath>
            <!-- Nueva pestaña para la galería de imágenes -->
            <xpath expr="//notebook" position="inside">
                <page string="Galería">
                    <button name="action_sync_all_images_from_disk"
                            type="object"
                            string="Sincronizar desde disco"
                            class="btn-primary"/>
                    <field name="gallery_image_ids">
                        <tree editable="bottom">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="filename"/>
                            <field name="relative_path"/>
                            <field name="is_main"/>
                            <field name="website_published"/>
                            <field name="image_url" widget="url"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Vista Tree para mostrar el nuevo campo gdrive_folder_id -->
    <record id="view_web_product_template_tree" model="ir.ui.view">
        <field name="name">web.product.template.tree</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="default_code"/>
                <field name="gdrive_folder_id"/>
            </tree>
        </field>
    </record>

    <!-- action para mostrar la vista tree de productos -->
    <record id="action_web_product_template_tree" model="ir.actions.act_window">
        <field name="name">Productos</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_web_product_template_tree"/>
        <!-- search personalizado-->
        <field name="search_view_id" ref="product.product_template_search_view"/>
        <field name="domain">[('gdrive_folder_id', '=', False), ('sale_ok', '=', True), ('default_code', '!=', False), ('default_code', 'not like', '9%')]</field>
    </record>
</odoo>
