<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="website_product_zip_button_inherit" inherit_id="website_sale.product">
    <xpath expr="//div[@class='col-md-6 mt-md-4'][1]" position="inside">
        <t t-if="product.gallery_image_ids">
            <div class="mt-3">
                <div class="row">
                    <t t-set="thumb_images"
                      t-value="product.gallery_image_ids.sorted(key=lambda r: ((0 if r.is_main else 1), r.sequence, r.id)).filtered(lambda r: not r.is_main)"/>
                    <t t-if="thumb_images">
                        <div class="row">
                            <t t-foreach="thumb_images" t-as="img">
                                <div class="col-3 mb-2">
                                    <a t-att-href="'/product-images/%s' % img.relative_path"
                                        target="_blank">
                                        <img t-att-src="'/product-images/%s' % img.relative_path"
                                              t-att-alt="img.name or product.name"
                                              class="img img-fluid border rounded"/>
                                    </a>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>

                <div class="mt-2 text-center" t-if="product.website_published">
                    <a t-att-href="'/shop/product/%s/download-images-zip' % product.id"
                        class="btn btn-secondary">
                        Descargar imágenes (ZIP)
                    </a>
                </div>
            </div>
        </t>
    </xpath>
  
    <xpath expr="//div[@id='product_details']" position="after">
        <t t-if="product.gallery_image_ids">
            <div class="mt-4">
                <h5>Galería</h5>

                <div class="row">
                    <t t-foreach="product.gallery_image_ids.sorted(key=lambda x: (x.sequence, x.id))" t-as="img">
                        <div class="col-6 col-md-3 mb-3">
                            <a t-att-href="'/product-images/%s' % img.relative_path"
                                target="_blank">
                                <img t-att-src="'/product-images/%s' % img.relative_path"
                                      t-att-alt="img.name or product.name"
                                      class="img img-fluid border rounded"/>
                            </a>

                            <div class="mt-2 text-center">
                                <a t-att-href="'/product-images/%s' % img.relative_path"
                                    class="btn btn-sm btn-outline-primary"
                                    download="1">
                                    Descargar
                                </a>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </xpath>
  </template>
</odoo>
