<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="views_import_sale_order_masive_wizard_form" model="ir.ui.view">
        <field name="name">import.sale.order.masive.wizard.form</field>
        <field name="model">import.sale.order.masive.wizard</field>
        <field name="arch" type="xml">
            <form string="Importar Pedido de Venta Masivo">
                <group>
                    <field name="file"/>
                    <field name="sheet_name"/>
                </group>
                <footer>
                    <button name="action_import_file" type="object" string="Importar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_sale_order_masive_wizard" model="ir.actions.act_window">
        <field name="name">Importar Pedidos de Venta Masivo</field>
        <field name="res_model">import.sale.order.masive.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>